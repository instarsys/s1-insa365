# ============================================
# s1-insa365 Production Environment Variables
# ============================================
# 이 파일을 .env.production으로 복사 후 실제 값 입력
# cp .env.production.example .env.production

# ── 필수 ──────────────────────────────────────

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@postgres:5432/insa365?schema=public"

# JWT Secrets (생성: openssl rand -hex 32)
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# PII Encryption Key (생성: openssl rand -hex 32)
PII_ENCRYPTION_KEY=""

# Node Environment
NODE_ENV="production"

# ── 선택: S3 호환 스토리지 (Cloudflare R2) ────

S3_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="insa365-files"
S3_PUBLIC_URL=""

# ── 선택: Sentry 에러 모니터링 ────────────────

# Server-side DSN
SENTRY_DSN=""
# Client-side DSN (브라우저에 노출됨)
NEXT_PUBLIC_SENTRY_DSN=""
# Source map 업로드용 (CI/CD에서만 필요)
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ── 선택: Kakao Maps / Geocoding (주소 검색 + 지도) ──

# JavaScript App Key (카카오 개발자 콘솔 → 앱 키)
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=""
# REST API Key
KAKAO_REST_API_KEY=""

# ── Post-MVP ──────────────────────────────────

# Redis (BullMQ 비동기 처리)
# REDIS_URL="redis://redis:6379"
