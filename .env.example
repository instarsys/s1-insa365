# Database
DATABASE_URL="postgresql://insa365:insa365dev@localhost:5438/insa365?schema=public"

# JWT (생성: openssl rand -hex 32)
JWT_ACCESS_SECRET="your-jwt-secret-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars"

# PII Encryption (AES-256-GCM, 생성: openssl rand -hex 32)
PII_ENCRYPTION_KEY="your-32-byte-hex-encryption-key"

# Redis (BullMQ) — Post-MVP
REDIS_URL="redis://localhost:6380"

# S3 Compatible Storage (Cloudflare R2)
S3_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_BUCKET="insa365-files"
S3_PUBLIC_URL=""

# Sentry
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
