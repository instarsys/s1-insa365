// ──────────────────────────────────────────────
// PayrollMonthly (월별 원천징수 이력)
// ──────────────────────────────────────────────

model PayrollMonthly {
  id                 String   @id @default(uuid())
  companyId          String   @map("company_id")
  company            Company  @relation(fields: [companyId], references: [id])
  userId             String   @map("user_id")
  user               User     @relation(fields: [userId], references: [id])
  year               Int
  month              Int
  totalPay           Decimal  @default(0) @map("total_pay") @db.Decimal(15, 0)
  taxableIncome      Decimal  @default(0) @map("taxable_income") @db.Decimal(15, 0)
  totalNonTaxable    Decimal  @default(0) @map("total_non_taxable") @db.Decimal(15, 0)
  nationalPension    Decimal  @default(0) @map("national_pension") @db.Decimal(15, 0)
  healthInsurance    Decimal  @default(0) @map("health_insurance") @db.Decimal(15, 0)
  longTermCare       Decimal  @default(0) @map("long_term_care") @db.Decimal(15, 0)
  employmentInsurance Decimal @default(0) @map("employment_insurance") @db.Decimal(15, 0)
  incomeTax          Decimal  @default(0) @map("income_tax") @db.Decimal(15, 0)
  localIncomeTax     Decimal  @default(0) @map("local_income_tax") @db.Decimal(15, 0)
  netPay             Decimal  @default(0) @map("net_pay") @db.Decimal(15, 0)
  payrollGroupId     String?  @map("payroll_group_id")
  payrollGroup       PayrollGroup? @relation(fields: [payrollGroupId], references: [id])

  // 불변 스냅샷 (확정 시 생성, 급여대장/명세서의 단일 소스)
  employeeName           String?  @map("employee_name")
  employeeNumber         String?  @map("employee_number")
  departmentName         String?  @map("department_name")
  salaryType             String?  @map("salary_type")
  payItemsSnapshot       Json?    @map("pay_items_snapshot")
  deductionItemsSnapshot Json?    @map("deduction_items_snapshot")
  attendanceSnapshot     Json?    @map("attendance_snapshot")
  snapshotMetadata       Json?    @map("snapshot_metadata")

  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([companyId, userId, year, month])
  @@index([companyId, year, month])
  @@index([companyId, payrollGroupId, year, month])
  @@map("payroll_monthlies")
}

// ──────────────────────────────────────────────
// LeaveRequest (휴가 신청)
// ──────────────────────────────────────────────

model LeaveRequest {
  id                String           @id @default(uuid())
  companyId         String           @map("company_id")
  company           Company          @relation(fields: [companyId], references: [id])
  userId            String           @map("user_id")
  user              User             @relation(fields: [userId], references: [id])
  type              LeaveType
  leaveTypeConfigId String?          @map("leave_type_config_id")
  leaveTypeConfig   LeaveTypeConfig? @relation(fields: [leaveTypeConfigId], references: [id])
  startDate         DateTime         @map("start_date") @db.Date
  endDate           DateTime         @map("end_date") @db.Date
  days              Decimal          @db.Decimal(5, 1)
  reason            String?
  status            LeaveStatus      @default(PENDING)
  approvedBy        String?          @map("approved_by")
  approvedAt        DateTime?        @map("approved_at")
  rejectedBy        String?          @map("rejected_by")
  rejectedAt        DateTime?        @map("rejected_at")
  rejectReason      String?          @map("reject_reason")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  deletedAt         DateTime?        @map("deleted_at")

  @@index([companyId, userId])
  @@index([companyId, status])
  @@map("leave_requests")
}

// ──────────────────────────────────────────────
// LeaveBalance (연차 잔여일수)
// ──────────────────────────────────────────────

model LeaveBalance {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id])
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  year        Int
  totalDays   Decimal  @default(0) @map("total_days") @db.Decimal(5, 1)
  usedDays    Decimal  @default(0) @map("used_days") @db.Decimal(5, 1)
  remainingDays Decimal @default(0) @map("remaining_days") @db.Decimal(5, 1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([companyId, userId, year])
  @@map("leave_balances")
}

// ──────────────────────────────────────────────
// Notification (인앱 알림)
// ──────────────────────────────────────────────

model Notification {
  id         String               @id @default(uuid())
  companyId  String               @map("company_id")
  company    Company              @relation(fields: [companyId], references: [id])
  userId     String               @map("user_id")
  user       User                 @relation(fields: [userId], references: [id])
  type       NotificationType
  priority   NotificationPriority @default(MEDIUM)
  title      String
  message    String
  isRead     Boolean              @default(false) @map("is_read")
  readAt     DateTime?            @map("read_at")
  link       String?
  createdAt  DateTime             @default(now()) @map("created_at")

  @@index([companyId, userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
