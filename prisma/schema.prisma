  effectiveEndDate   DateTime @map("effective_end_date") @db.Date
  description        String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([type, effectiveStartDate, effectiveEndDate])
  @@map("insurance_rates")
}

// ──────────────────────────────────────────────
// TaxBracket (간이세액표)
